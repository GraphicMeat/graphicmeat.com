# Contact form mail delivery (Purelymail SMTP)
# Copy to .env and fill in. NEVER commit .env.
SMTP_HOST=smtp.purelymail.com
# Use 587 STARTTLS — the Hetzner box blocks outbound 465.
SMTP_PORT=587
SMTP_SECURE=false
# Outbound identity. If unset, app.js defaults SMTP_USER to grill@graphicmeat.com
# and reads the password from GRILL_EMAIL_SMTP_APP_PASSWORD (below).
# SMTP_USER=grill@graphicmeat.com
# SMTP_PASS=...   # or set GRILL_EMAIL_SMTP_APP_PASSWORD instead
GRILL_EMAIL_SMTP_APP_PASSWORD=your-purelymail-app-password
# Where contact form submissions are delivered (a mailbox you can read):
CONTACT_TO=prime@graphicmeat.com
# From address on outbound mail (defaults to SMTP_USER = grill@graphicmeat.com):
# CONTACT_FROM=grill@graphicmeat.com

# Newsletter (double opt-in) — MariaDB/MySQL on the Hetzner VPS.
# Reuses the SMTP settings above to send the confirm + notification emails.
DB_HOST=localhost
DB_PORT=3306
DB_USER=graphicmeat
DB_PASS=your-db-password
DB_NAME=graphicmeat
# Absolute base URL used to build the email confirmation link:
SITE_URL=https://graphicmeat.com
# Where "new subscriber" notifications are sent (defaults to CONTACT_TO if unset):
NEWSLETTER_NOTIFY=prime@graphicmeat.com
# Salt for hashing stored subscriber IPs (set to any long random string):
IP_SALT=change-me-to-a-long-random-string

# Server port (set by your process manager / nginx upstream on the Hetzner VPS)
PORT=3000

# Self-hosted analytics (meatlytics) — see /_analytics on this site once running.
# Dashboard login is passkey-based (first boot logs a one-time setup link).
# API key used for hub pulls (a peer site's dashboard fetching this site's stats);
# optional — meatlytics mints and stores one itself when unset:
ANALYTICS_API_KEY=change-me-to-a-long-random-string
# Optional: makes this dashboard a hub that also shows the mailvault site.
# Only set both if that site's meatlytics is reachable from here.
# MAILVAULT_ANALYTICS_URL=https://mailvaultapp.com
# MAILVAULT_ANALYTICS_KEY=the-api-key-mailvault-issued-for-this-peer

# Admin API key for GET /api/admin/subscribers (x-admin-key header):
ADMIN_KEY=change-me-to-a-long-random-string
