# Contact form mail delivery (Purelymail SMTP)
# Copy to .env and fill in. NEVER commit .env.
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=prime@graphicmeat.com
SMTP_PASS=your-purelymail-password-or-app-password
# Where contact form submissions are delivered:
CONTACT_TO=prime@graphicmeat.com
# From address shown on the sent mail (should be a mailbox you own on the domain):
CONTACT_FROM=prime@graphicmeat.com

# Newsletter (double opt-in) — MariaDB/MySQL on the Hetzner VPS.
# Reuses the SMTP settings above to send the confirm + notification emails.
DB_HOST=localhost
DB_PORT=3306
DB_USER=graphicmeat
DB_PASS=your-db-password
DB_NAME=graphicmeat
# Absolute base URL used to build the email confirmation link:
SITE_URL=https://graphicmeat.com
# Where "new subscriber" notifications are sent (defaults to CONTACT_TO if unset):
NEWSLETTER_NOTIFY=prime@graphicmeat.com
# Salt for hashing stored subscriber IPs (set to any long random string):
IP_SALT=change-me-to-a-long-random-string

# Server port (set by your process manager / nginx upstream on the Hetzner VPS)
PORT=3000
